{
  "name": "@aer-org/art",
  "version": "0.2.0",
  "description": "ART — Agent Runtime for software projects",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aer-org/art.git"
  },
  "license": "AGPL-3.0",
  "type": "module",
  "main": "dist/run-engine.js",
  "bin": {
    "art": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "npm run build && node -e \"try{require('husky')}catch{process.exit(0)}\" && husky || true",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
